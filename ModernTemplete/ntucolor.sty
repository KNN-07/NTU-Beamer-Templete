\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{ntucolor}[2026/06/12]

\RequirePackage{xcolor}

% NTU corporate palette from NTUBrandingGuide.md.
\definecolor{maincolor}{RGB/cmyk}{24,28,98/100,95,5,40}

% Greys
\definecolor{ntugrey}{RGB/cmyk}{230,230,230/0,0,0,.1}
\definecolor{ntumidgrey}{RGB/cmyk}{200,200,200/0,0,0,.25}
\definecolor{ntudarkgrey}{RGB/cmyk}{140,140,140/0,0,0,.55}
\colorlet{ntugray}{ntugrey}
