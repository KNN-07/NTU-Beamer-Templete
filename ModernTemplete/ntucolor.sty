% Blue-forward secondary palette
\definecolorset{RGB/cmyk}{ntu}{}{brightblue, 0,84,166/100,75,0,0;%
                                 mediumblue, 27,117,188/86,50,0,0;%
                                 lightblue, 93,169,221/60,20,0,0;%
                                 teal, 50,188,173/70,0,40,0}

% Supporting colours
\definecolorset{RGB/cmyk}{ntu}{}{green, 7,177,82/80,0,95,0;%
                                 darkgreen, 0,124,72/100,10,90,26;%
                                 yellow, 255,221,0/0,10,100,0}

